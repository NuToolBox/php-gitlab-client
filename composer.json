{
    "name": "nutoolbox/php-gitlab-client",
    "description": "A modern, type-safe PHP client for the GitLab REST API built on PSR standards.",
    "type": "library",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "NuToolBox\\Gitlab\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NuToolBox\\Gitlab\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "NuSphere",
            "email": "nusphere83@gmail.com"
        }
    ],
    "scripts": {
        "test": "phpunit",
        "lint": "phpstan analyse",
        "cs": "phpcs"
    },
    "require": {
        "php": "^8.2",
        "psr/http-message": "^1.0",
        "psr/http-client": "^1.0",
        "php-http/discovery": "^1.17",
        "symfony/http-client": "^7.4",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^4.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
